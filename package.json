{
  "name": "cheetah-backend",
  "version": "1.0.0",
  "description": "猎豹出海工具箱 - 后端 API",
  "main": "src/app.js",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "admin:dev": "cd admin && npx vite",
    "admin:build": "cd admin && npx vite build",
    "test": "jest --testTimeout=10000 --forceExit"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "mysql2": "^3.6.5",
    "redis": "^4.6.10"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "vite": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}